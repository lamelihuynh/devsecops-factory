# =============================================================================
# shared/contracts/env-template.env
#
# Copy this to .env (git-ignored) and fill in your values.
# NEVER commit .env — it contains secrets.
#
# Each section is owned by a different team.
# Teams only fill in their section. Do not touch other sections.
# =============================================================================

# ─────────────────────────────────────────────────────────
# [TEAM 1 — INFRA] Fill these
# ─────────────────────────────────────────────────────────
REGISTRY=localhost:5001          # Local. Change to ECR URL for cloud.
KUBECONFIG_PATH=~/.kube/devsecops-local.kubeconfig
GITEA_ADMIN_USER=gitadmin
GITEA_ADMIN_PASS=gitadmin123     # Change this
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASS=admin123      # Change this

# Cloud only (leave empty for local)
AWS_REGION=
AWS_ACCOUNT_ID=
EKS_CLUSTER_NAME=

# ─────────────────────────────────────────────────────────
# [TEAM 2 — SECURITY] Fill these
# ─────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────
# [TEAM 3 — APP] Fill these
# ─────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────
# [SHARED — do not change unless all teams agree]
# ─────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=devsecops
DOCKER_NETWORK=devsecops
