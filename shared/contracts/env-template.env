# =============================================================================
# shared/contracts/env-template.env
#
# Copy this to .env (git-ignored) and fill in your values.
# NEVER commit .env — it contains secrets.
#
# Each section is owned by a different team.
# Teams only fill in their section. Do not touch other sections.
# =============================================================================

# ─────────────────────────────────────────────────────────
# [TEAM 1 — INFRA] Fill these
# ─────────────────────────────────────────────────────────
REGISTRY=localhost:5001          # Local. Change to ECR URL for cloud.
KUBECONFIG_PATH=~/.kube/devsecops-local.kubeconfig
GITEA_ADMIN_USER=gitadmin
GITEA_ADMIN_PASS=gitadmin123     # Change this
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASS=admin123      # Change this

# Cloud only (leave empty for local)
AWS_REGION=
AWS_ACCOUNT_ID=
EKS_CLUSTER_NAME=

# ─────────────────────────────────────────────────────────
# [TEAM 2 — SECURITY] Fill these
# ─────────────────────────────────────────────────────────
SONAR_TOKEN=                     # Generated after SonarQube first boot
SONAR_PROJECT_KEY=tetris-devsecops
DEFECTDOJO_API_KEY=              # Generated after DefectDojo first boot
DEFECTDOJO_PRODUCT_NAME=Tetris-DevSecOps

# Scan thresholds — Team 2 owns these values
TRIVY_SEVERITY=HIGH,CRITICAL     # Fail on these
TRIVY_EXIT_CODE=1                # 1 = fail pipeline on findings
SONAR_QUALITY_GATE=true          # Block pipeline if gate fails
OWASP_FAIL_CVSS=8               # CVSS score to fail SCA

# ─────────────────────────────────────────────────────────
# [TEAM 3 — APP] Fill these
# ─────────────────────────────────────────────────────────
APP_NAME=tetris-devsecops
STAGING_URL=http://tetris-staging.localhost
PRODUCTION_URL=http://tetris.localhost
GITOPS_REPO_URL=http://localhost:3000/gitadmin/tetris-gitops.git
ARGOCD_URL=https://localhost:8443
GRAFANA_ADMIN_PASS=admin123      # Change this

# ─────────────────────────────────────────────────────────
# [SHARED — do not change unless all teams agree]
# ─────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=devsecops
DOCKER_NETWORK=devsecops
