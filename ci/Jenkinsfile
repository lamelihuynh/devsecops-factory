// ====================================================
// Jenkins File - DevSecOps Full Pipeline
// ====================================================
// 12-stage pipeline:
// 1. Checkout source from GitHub
// 2. Prepare metadata (Git commit tag, build number)
// 3. Secrets scan (Gitleaks, TruffleHog)
// 4. SCA scan (OWASP Dependency-Check)
// 5. SAST scan (SonarQube)
// 6. Build Docker image
// 7. Container scan (Trivy)
// 8. IaC scan (Checkov on K8s manifests)
// 9. Push image to AWS ECR
// 10. Summary & reporting
// ====================================================

def     IMAGE_TAG = ""
def     IMAGE_URI = ""
def     GIT_COMMIT_SHORT = ""

pipeline {
  agent any

  environment{
    AWS_REGION= 'ap-southeast-1'
    AWS_ACCOUNT_ID = '158909020071'
    ECR_REPO = 'devsecops/ecr'
    REGISTRY = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
    IMAGE_NAME = "${REGISTRY}/${ECR_REPO}"
    SONAR_HOST = "${SONAR_HOST}"
    DEFECTDOJO_URL = "${DEFECTDOJO_URL}"

    SCAN_REPORT_DIR = "${WORKSPACE}/scan-reports"
  }


  options{
    // timestamps()
    timeout(time: 1, unit: 'HOURS')
    disableConcurrentBuilds()
    buildDiscarder(logRotator(numToKeepStr: '10'))
  }

  stages{// Stage 1: Lấy code của chính mình (không mượn của Linh nữa)
    stage('1. Checkout') {
      steps {
        script {
          // Lệnh 'checkout scm' sẽ tự lấy đúng repo và branch mà ní đang chạy
          def scmVars = checkout scm
          
          if (scmVars && scmVars.GIT_COMMIT) {
            // Cắt lấy 7 ký tự đầu của mã Commit (Short SHA)
            env.GIT_COMMIT_SHORT = scmVars.GIT_COMMIT.substring(0, 7)
          } else {
            // Nếu không lấy được mã commit (hiếm gặp), dùng số build làm backup
            env.GIT_COMMIT_SHORT = "build-${env.BUILD_NUMBER}"
          }
          
          echo "==== CHECKOUT XONG ===="
          echo "Mã Commit rút gọn: ${env.GIT_COMMIT_SHORT}"
        }
      }
    }

    // Stage 2: Thiết lập thông tin cho các bước sau
    stage('2. Prepare Metadata'){
      steps{
        script{
          // Tạo folder chứa báo cáo
          sh "mkdir -p ${env.SCAN_REPORT_DIR}"
          
          // Gán Tag và URI chuẩn để các stage sau (Build/Push ECR) dùng chung
          env.IMAGE_TAG = env.GIT_COMMIT_SHORT
          env.IMAGE_URI = "${env.IMAGE_NAME}:${env.IMAGE_TAG}"
          
          echo "==== METADATA READY ===="
          echo "Image TAG  : ${env.IMAGE_TAG}"
          echo "Image URI  : ${env.IMAGE_URI}"
          echo "Reports at : ${env.SCAN_REPORT_DIR}" 
        }
      }
    }

//     stage('3. Secrets Scan'){
